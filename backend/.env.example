# ── Vercel 대시보드에서 자동 설정되는 값들 ──────────────────────────
# Vercel > Storage > Postgres 연결 시 자동 주입됨
POSTGRES_URL=

# Vercel > Storage > Blob 연결 시 자동 주입됨
BLOB_READ_WRITE_TOKEN=

# ── 직접 설정해야 하는 값들 ──────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Vercel Cron 요청 검증용 시크릿 (임의의 랜덤 문자열)
CRON_SECRET=your-cron-secret-key

# 회사 SMTP 서버 설정
SMTP_HOST=mail.yourcompany.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourname@yourcompany.com
SMTP_PASS=yourpassword
SMTP_FROM=yourname@yourcompany.com
